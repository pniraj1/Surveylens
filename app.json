{
  "expo": {
    "name": "SurveyLens",
    "slug": "surveylens",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.surveylens.app",
      "minSdkVersion": 24,
      "targetSdkVersion": 34,
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO"
      ],
      "config": {
        "googleMobileAdsAppId": "ca-app-pub-6365268430069678~9213608900"
      }
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow SurveyLens to access your camera to capture survey photos."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow SurveyLens to use your location to geotag photos."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow SurveyLens to save photos.",
          "savePhotosPermission": "Allow SurveyLens to save photos.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "extra": {
      "admobBanner":       "ca-app-pub-6365268430069678/9574699422",
      "admobInterstitial": "ca-app-pub-6365268430069678/8814987800",
      "admobRewarded":     "ca-app-pub-6365268430069678/6002644716"
    }
  }
}
